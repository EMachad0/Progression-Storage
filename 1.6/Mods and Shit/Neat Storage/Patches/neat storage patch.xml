<?xml version="1.0" encoding="utf-8" ?>
<Patch>        

    <!-- TEXTILE RACK -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_TextileRack"]/description</xpath>
        <value>
            <description>A textile rack for storing fabrics.</description>
        </value>
    </Operation>

    <!-- CRATES -->
    <!-- SMALL CRATE -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="sbz_SmallCrate"]</xpath>
        <value>
            <building>
                <maxItemsInCell>8</maxItemsInCell>
            </building>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_SmallCrate"]/label</xpath>
        <value>
            <label>small container</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_SmallCrate"]/description</xpath>
        <value>
            <description>A small container for storing a variety of items.</description>
        </value>
    </Operation>
    <!-- MID CRATE -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="sbz_MidCrate"]</xpath>
        <value>
            <building>
                <maxItemsInCell>9</maxItemsInCell>
            </building>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_MidCrate"]/label</xpath>
        <value>
            <label>medium container</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_MidCrate"]/description</xpath>
        <value>
            <description>A medium container for storing a variety of items.</description>
        </value>
    </Operation>
    <!-- LARGE CRATE -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="sbz_Crate"]</xpath>
        <value>
            <building>
                <maxItemsInCell>10</maxItemsInCell>
            </building>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_Crate"]/label</xpath>
        <value>
            <label>large container</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_Crate"]/description</xpath>
        <value>
            <description>A large container for storing a variety of items.</description>
        </value>
    </Operation>
    <!-- TALL CRATE -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="sbz_TallCrate"]</xpath>
        <value>
            <building>
                <maxItemsInCell>10</maxItemsInCell>
            </building>
        </value>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="sbz_TallCrate"]/label</xpath>
        <value>
            <label>tall container</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_TallCrate"]/description</xpath>
        <value>
            <description>A tall container for storing a variety of items.</description>
        </value>
    </Operation>

<!-- VE FURNITURE -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Furniture Expanded</li>
		</mods>
            <match Class="PatchOperationSequence">
                <operations>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[defName="Shelf_WeaponRack"]/label</xpath>
                        <value>
                            <label>small weapon rack</label>
                        </value>
                    </li>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[@Name="sbzWeaponRackBase"]/costStuffCount</xpath>
                        <value>
                            <costStuffCount>50</costStuffCount>
                        </value>
                    </li>
                </operations>
            </match>
	</Operation>






<!-- REEL -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Reel's Expanded Storage</li>
		</mods>
            <match Class="PatchOperationSequence">
                <operations>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[@Name="sbzCrateBase"]/researchPrerequisites</xpath>
                        <value>
                            <researchPrerequisites>
                                <li>ReelNeolithicStorage</li>
                            </researchPrerequisites>
                        </value>
                    </li>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[@Name="sbzDisplayShelfBase"]/researchPrerequisites</xpath>
                        <value>
                            <researchPrerequisites>
                                <li>ReelNeolithicStorage</li>
                            </researchPrerequisites>
                        </value>
                    </li>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[@Name="sbzSmallDisplayShelfBase"]/researchPrerequisites</xpath>
                        <value>
                            <researchPrerequisites>
                                <li>ReelNeolithicStorage</li>
                            </researchPrerequisites>
                        </value>
                    </li>

                    <li Class="PatchOperationAdd">
                        <xpath>Defs/ThingDef[@Name="sbzWeaponRackBase"]</xpath>
                        <value>
                            <researchPrerequisites>
                                <li>ReelIndustrialStorage</li>
                            </researchPrerequisites>
                        </value>
                    </li>

                    <li Class="PatchOperationAdd">
                        <xpath>Defs</xpath>
                        <value>
							<VEF.Buildings.HiddenDesignatorsDef>
								<defName>FernyNeatStorageReelStorageProgStorage_HiddenDesignators</defName>
								<hiddenDesignators>
									<li>sbz_MeatHook</li>
                                    <li>ReelNewIndustrialShelf</li>
                                    <li>sbz_WeaponRack</li>
                                    <li>sbz_HorizontalWeaponRack</li>
                                    <li>sbz_VerticalWeaponRack</li>
                                    <li>sbz_SmallCrate</li>
                                    <li>sbz_Crate</li>
								</hiddenDesignators>
							</VEF.Buildings.HiddenDesignatorsDef>
                        </value>
                    </li>
                </operations>
            </match>
	</Operation>


<!-- MEDIEVAL OVERHAUL -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Medieval Overhaul</li>
		</mods>
            <match Class="PatchOperationSequence">
                <operations>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[@Name="sbzCrateBase"]/researchPrerequisites</xpath>
                        <value>
                            <researchPrerequisites>
                                <li>DankPyon_RusticStorage</li>
                            </researchPrerequisites>
                        </value>
                    </li>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[@Name="sbzDisplayShelfBase"]/researchPrerequisites</xpath>
                        <value>
                            <researchPrerequisites>
                                <li>DankPyon_RusticStorage</li>
                            </researchPrerequisites>
                        </value>
                    </li>
                    <li Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[@Name="sbzSmallDisplayShelfBase"]/researchPrerequisites</xpath>
                        <value>
                            <researchPrerequisites>
                                <li>DankPyon_RusticStorage</li>
                            </researchPrerequisites>
                        </value>
                    </li>
                </operations>
            </match>
	</Operation>


</Patch>
