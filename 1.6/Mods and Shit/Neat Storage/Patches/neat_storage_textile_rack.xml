<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <!-- TEXTILE RACK -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_TextileRack"]/description</xpath>
        <value>
            <description>A textile rack for storing fabrics.</description>
        </value>
    </Operation>

    <!-- MEAT HOOK -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_MeatHook"]/building/maxItemsInCell</xpath>
        <value>
            <maxItemsInCell>8</maxItemsInCell>
        </value>
    </Operation>

    <!-- WEAPON RACKS -->
    <!-- Small weapon rack (sbz_WeaponRack) intentionally unchanged. -->
    <!-- HORIZONTAL + VERTICAL RACKS -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="sbzWeaponRackBase"]/building/maxItemsInCell</xpath>
        <value>
            <maxItemsInCell>8</maxItemsInCell>
        </value>
    </Operation>

</Patch>
