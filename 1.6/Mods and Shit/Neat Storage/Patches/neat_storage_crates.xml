<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <!-- SMALL CRATE -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="sbz_SmallCrate"]</xpath>
        <value>
            <building>
                <maxItemsInCell>6</maxItemsInCell>
            </building>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_SmallCrate"]/label</xpath>
        <value>
            <label>small container</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="sbz_SmallCrate"]/description</xpath>
        <value>
            <description>A sturdy wooden container designed for storing small quantities of goods and valuables. Items stored inside will not deteriorate over time and have no impact on the beauty of their surroundings.</description>
        </value>
    </Operation>

